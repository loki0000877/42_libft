#include <libft.h>

int  ft_atoi(const char *nptr)
{
  size_t  i;
  int  sign;
  int  value;

  value = 0;
  sign = 1;
  i = 0;
  if (!nptr)
    return 0;
  while (ft_isspace(nptr[i]))
    i++;
  if (nptr[i] == '-')
  {
    sign = -1;
    i++;
  }
  else if (nptr[i] == '+')
    i++;
  while (nptr[i] && ft_isdigit(nptr[i]))
  {
    value = value * 10 + nptr[i] - '0';
    i++;
  }
  return (value * sign);
}
