#include <ftlib.h>

size_t  ft_strlcat(char *dst, const char *src, size_t dsize)
{
  size_t  i;
  size_t  dlen;
  size_t  slen;
  
  dlen = ft_strlen(dst);
  slen = ft_strlen(src);
  i = 0;
  if (dlen >= dsize)
    return (dsize + slen);
  while (dlen + i < dsize - 1 && src[i])
  {
    dst[dlen + i] = src[i];
    i++;
  }
  dst[dlen + i] = '\0';
  return (dlen + slen);
}
